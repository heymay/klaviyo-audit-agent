# ── FastAPI backend (Railway) ──────────────────────────────────────────────────
# Supabase — for audit persistence. Leave blank to use in-memory fallback (local dev).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Next.js frontend (Vercel) ──────────────────────────────────────────────────
# FastAPI backend URL — set after Railway deploy
AUDIT_API_URL=https://your-railway-app.railway.app

# Supabase — public keys for the browser client
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL — used for absolute links / og tags
NEXT_PUBLIC_APP_URL=https://your-vercel-app.vercel.app
